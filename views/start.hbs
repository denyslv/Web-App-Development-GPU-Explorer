{{> menu}}

<section class="ui center aligned middle aligned segment">
  <h2 class="ui header">GPU Explorer</h2>

  <p>
    This web app lets you browse latest GPUs from NVIDIA and AMD.
    You can use it to compare compute, power usage, VRAM size, and release dates.
  </p>

  <div style="margin-top: 2rem;">
    <a class="ui big primary button" href="/dashboard">
      View GPU Collection
    </a>
  </div>
</section>
<section class="ui segment">
  <div class="ui three statistics">
    <div class="statistic">
      <div class="value">{{stats.totalCategories}}</div>
      <div class="label">Categories</div>
    </div>
    <div class="statistic">
      <div class="value">{{stats.totalGpus}}</div>
      <div class="label">GPUs</div>
    </div>
    <div class="statistic">
      <div class="value">{{stats.avgComputePowerTF}}</div>
      <div class="label">Avg TF</div>
    </div>
  </div>
</section>
