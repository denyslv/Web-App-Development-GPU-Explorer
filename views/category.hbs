{{> menu}}

<section class="ui segment">
  <h2 class="ui header">{{category.name}}</h2>

  <p>
    GPUs in this category.
  </p>

  <table class="ui celled table" style="margin-top: 1rem;">
    <thead>
      <tr>
        <th>Model</th>
        <th>Compute Power (TF)</th>
        <th>Power (W)</th>
        <th>VRAM (GB)</th>
        <th>Release Date</th>
      </tr>
    </thead>
    <tbody>
      {{#each gpus}}
        <tr>
          <td>{{name}}</td>
          <td>{{computePowerTF}}</td>
          <td>{{powerWatts}}</td>
          <td>{{vramGB}}</td>
          <td>{{releaseDate}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  {{#if canEditCategory}}
    <details style="margin-top: 1rem; margin-bottom: 1rem;">
      <summary class="ui primary button">Add items</summary>
      <div class="ui segment" style="margin-top: 1rem;">
        <h3 class="ui dividing header">Add GPU</h3>
        <form class="ui form segment" style="width: 100%; box-sizing: border-box;" action="/category/{{category.id}}/gpu" method="POST">
          <div class="two fields">
            <div class="field">
              <label>Model</label>
              <input type="text" name="name" autofocus required title="Please include a valid GPU model" placeholder="e.g. GeForce RTX 4070">
            </div>
            <div class="field">
              <label>Release Date</label>
              <input type="date" name="releaseDate" required title="Please include a valid release date">
            </div>
          </div>
          <div class="three fields">
            <div class="field">
              <label>Compute TF</label>
              <input type="number" step="0.1" min="0" name="computePowerTF" required title="Please include valid compute value" placeholder="e.g. 37.3">
            </div>
            <div class="field">
              <label>Power W</label>
              <input type="number" min="0" name="powerWatts" required title="Please include valid power usage" placeholder="e.g. 200">
            </div>
            <div class="field">
              <label>VRAM GB</label>
              <input type="number" min="0" name="vramGB" required title="Please include valid VRAM value" placeholder="e.g. 12">
            </div>
          </div>
          <button class="ui blue submit button" type="submit">Add GPU</button>
        </form>
      </div>
    </details>
  {{else}}
    <div class="ui info message" style="margin-top: 1rem;">
      This is a read-only default category.
    </div>
  {{/if}}

  <a class="ui button" href="/dashboard">Back to dashboard</a>
</section>

