{{> menu}}

<section class="ui segment">
  <h2 class="ui header">About GPU Explorer</h2>

  <p>
    This app was created as a simple collection of desktop GPUs for a web development assignment.
    It gives a quick overview of compute power, power usage, memory size, and release dates for a small set of modern graphics cards.
  </p>

  <h3 class="ui dividing header">Author</h3>
  <div class="ui list">
    <div class="item">
      <strong>Name:</strong>&nbsp;{{author.name}}
    </div>
    <div class="item">
      <strong>Company:</strong>&nbsp;{{author.company}}
    </div>
    <div class="item">
      <strong>Email:</strong>&nbsp;{{author.email}}
    </div>
  </div>

  <h3 class="ui dividing header">Location</h3>
  <p>
    Waterford, Ireland.
  </p>

  <h3 class="ui dividing header">App statistics</h3>
  <div class="ui three statistics">
    <div class="statistic">
      <div class="value">{{stats.totalCategories}}</div>
      <div class="label">Categories</div>
    </div>
    <div class="statistic">
      <div class="value">{{stats.totalGpus}}</div>
      <div class="label">GPUs</div>
    </div>
    <div class="statistic">
      <div class="value">{{stats.avgComputePowerTF}}</div>
      <div class="label">Avg TF</div>
    </div>
  </div>
</section>

